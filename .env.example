# ===================================================================
# GC2 Entrenamiento — Variables de entorno
# ===================================================================
# Copiar a .env.local y completar. NUNCA committear .env.local.
# Dos entornos (ver docs/environments.md):
#   dev  → Supabase gc2-dev  (Vercel Preview)
#   prod → Supabase gc2-prod (Vercel Production)
# En local apuntá SIEMPRE al proyecto gc2-dev, nunca a prod.
# ===================================================================

# Supabase — DISTINTO por entorno (dev usa gc2-dev, prod usa gc2-prod)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — compartido entre entornos
RESEND_API_KEY=
RESEND_FROM_NAME=GC2 Entrenamiento
RESEND_FROM_EMAIL=onboarding@resend.dev
COMPANY_EMAIL=gc2entrenamiento@gmail.com

# Google Analytics 4 — solo en prod (dejar vacío en dev para no medir tráfico de prueba)
NEXT_PUBLIC_GA_ID=
