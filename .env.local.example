# Supabase — copiar a `.env.local` y completar con valores reales del proyecto
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Resend (opcional, formulario de contacto). Si no se setea, el formulario igual guarda en DB.
RESEND_API_KEY=

# Google Analytics (opcional)
NEXT_PUBLIC_GA_ID=
